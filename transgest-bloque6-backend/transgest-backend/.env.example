# ══════════════════════════════════════════════════════
# TRANSGEST TMS — Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# NUNCA subas .env a git
# ══════════════════════════════════════════════════════

# ── Base de datos ──────────────────────────────────────
DB_NAME=transgest
DB_USER=transgest_user
DB_PASSWORD=CAMBIA_ESTA_CONTRASEÑA_SEGURA   # mín. 20 caracteres

# ── JWT ────────────────────────────────────────────────
JWT_SECRET=CAMBIA_ESTE_SECRET_LARGO_Y_ALEATORIO_MIN_64_CHARS
JWT_EXPIRES_IN=8h          # Sesión de 8h. Puedes usar: 1d, 12h, 30m
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
REQUEST_BODY_LIMIT=8mb
ALLOW_DEMO_SEED=false
APP_RELEASE=
API_KEYS_ENCRYPTION_SECRET=CAMBIA_OTRO_SECRET_LARGO_PARA_CIFRAR_APIS

# ── SMTP (correo saliente) ─────────────────────────────
SMTP_HOST=smtp.tuproveedor.com
SMTP_PORT=587
SMTP_USER=notificaciones@tuempresa.com
SMTP_PASS=TU_CONTRASEÑA_SMTP
SMTP_FROM="TransGest TMS <notificaciones@tuempresa.com>"

# ── URLs ───────────────────────────────────────────────
FRONTEND_URL=https://tudominio.com
APP_URL=https://tudominio.com
PUBLIC_APP_URL=https://tudominio.com
APP_PUBLIC_URL=https://tudominio.com
CORS_ORIGINS=https://tudominio.com,https://www.tudominio.com
ACCOUNTING_FRONTEND_URL=http://localhost:8080
ACCOUNTING_JWT_SECRET=CAMBIA_ESTE_SECRET_CONTABLE_O_REUTILIZA_UN_SECRETO_GESTIONADO
ACCOUNTING_SSO_JWT_SECRET=CAMBIA_ESTE_SECRET_SSO_COMPARTIDO_ENTRE_TRANSGEST_Y_CONTABILIDAD
ACCOUNTING_SSO_EXPIRES_IN=2m
ACCOUNTING_API_DB_USER=transgest_accounting_api
ACCOUNTING_API_DB_PASSWORD=CAMBIA_ESTA_CONTRASENA_API_CONTABLE
ACCOUNTING_WORKER_DB_USER=transgest_accounting_worker
ACCOUNTING_WORKER_DB_PASSWORD=CAMBIA_ESTA_CONTRASENA_WORKER_CONTABLE
ACCOUNTING_LEGACY_RUNTIME_DB_USER=transgest_accounting_app
ACCOUNTING_OUTBOX_CONSUMER_NAME=accounting-internal-v1
ACCOUNTING_OUTBOX_POLL_INTERVAL_MS=1000
ACCOUNTING_OUTBOX_LEASE_SECONDS=60
ACCOUNTING_OUTBOX_MAX_ATTEMPTS=5
ACCOUNTING_CHECK_TRANSGEST_URL=http://localhost
ACCOUNTING_CHECK_API_URL=http://localhost:3011
ACCOUNTING_CHECK_USER=gerente@empresa.com
ACCOUNTING_CHECK_PASSWORD=CAMBIA_ESTA_CONTRASENA_SOLO_PARA_SMOKE_LOCAL
ACCOUNTING_CHECK_UNAUTHORIZED_USER=trafico@empresa.com
ACCOUNTING_CHECK_UNAUTHORIZED_PASSWORD=CAMBIA_ESTA_CONTRASENA_SOLO_PARA_SMOKE_LOCAL
ACCOUNTING_CHECK_TIMEOUT_MS=8000

# Stripe SaaS
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=https://tudominio.com
STRIPE_CANCEL_URL=https://tudominio.com
STRIPE_PRICE_BASICO_MENSUAL=price_xxx
STRIPE_PRICE_BASICO_ANUAL=price_xxx
STRIPE_PRICE_PROFESIONAL_MENSUAL=price_xxx
STRIPE_PRICE_PROFESIONAL_ANUAL=price_xxx
STRIPE_PRICE_ENTERPRISE_MENSUAL=price_xxx
STRIPE_PRICE_ENTERPRISE_ANUAL=price_xxx

# Routing / optimizacion de rutas
# local = sin API, solo enlace orientativo
# ors   = OpenRouteService heavy vehicle (opcion gratuita con limites)
# here  = HERE Routing API truck (opcion premium recomendada)
ROUTING_PROVIDER=here
ORS_API_KEY=
HERE_API_KEY=
ROUTING_TIMEOUT_MS=12000

# IA
# IA configurable desde SuperAdmin. ai_generic admite cualquier API compatible
# con OpenAI indicando AI_BASE_URL y AI_MODEL.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=anthropic
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# GPS / localizacion de vehiculos
# Tambien configurable desde SuperAdmin por empresa.
LOCATEL_API_KEY=
TACOGEST_API_KEY=
MOVILDATA_API_KEY=
GPS_API_KEY=

# ── Backups ────────────────────────────────────────────
BACKUP_KEEP_DAYS=30                         # Días que se conservan los backups

# ── pgAdmin (solo perfil dev) ──────────────────────────
PGADMIN_EMAIL=admin@transgest.local
PGADMIN_PASSWORD=CAMBIA_ESTO_TAMBIEN
