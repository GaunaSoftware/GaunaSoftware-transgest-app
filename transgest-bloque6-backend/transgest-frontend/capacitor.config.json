{
  "appId": "com.transgest.chofer",
  "appName": "TransGest Chofer",
  "webDir": "build",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "Geolocation": {
      "permissions": [
        "location"
      ]
    },
    "Camera": {
      "permissions": [
        "camera",
        "photos"
      ]
    }
  }
}
