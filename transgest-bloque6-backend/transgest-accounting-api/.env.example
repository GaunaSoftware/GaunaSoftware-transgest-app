# === TransGest Contabilidad - API (Render Web Service) ===

# ---- Secretos JWT ----
# ACCOUNTING_SSO_JWT_SECRET debe ser EXACTAMENTE el mismo valor que el que
# pongas en el backend TMS (transgest-backend). Con el se verifica el token SSO
# que llega desde el TMS. Si no coincide, "Abrir Contabilidad" dara error de token.
ACCOUNTING_SSO_JWT_SECRET=pon-aqui-un-secreto-largo-igual-que-en-el-TMS
# Secreto propio para las sesiones internas de la contabilidad (puede ser distinto).
ACCOUNTING_JWT_SECRET=pon-aqui-otro-secreto-largo-solo-de-contabilidad
# Duracion de la sesion contable.
ACCOUNTING_JWT_EXPIRES_IN=8h

# ---- Ingesta de facturas desde el TMS (opcional pero recomendado) ----
# Debe coincidir con ACCOUNTING_INGEST_KEY del backend TMS. Sirve para que el TMS
# empuje cada factura emitida al libro de IVA de la contabilidad.
ACCOUNTING_INGEST_KEY=pon-aqui-una-clave-compartida-con-el-TMS

# ---- CORS ----
# URL(es) del frontend contable (Vercel), separadas por coma. Sin barra final.
ACCOUNTING_CORS_ORIGINS=https://transgest-contabilidad.vercel.app

# ---- Base de datos ----
# Puede ser LA MISMA base Postgres del TMS: la contabilidad vive en su propio
# esquema ("accounting"), no pisa las tablas del TMS. Copia aqui los mismos
# datos de conexion que usa el TMS en Render (Internal Database URL -> partes).
ACCOUNTING_DB_HOST=dpg-xxxxxxxx-a.frankfurt-postgres.render.com
ACCOUNTING_DB_PORT=5432
ACCOUNTING_DB_NAME=transgest
ACCOUNTING_DB_USER=transgest_user
ACCOUNTING_DB_PASSWORD=pon-aqui-la-password-de-la-base
ACCOUNTING_DB_SSL=true
ACCOUNTING_DB_SCHEMA=accounting

# Render fija PORT automaticamente; no hace falta tocarlo.
# PORT=3011
